{
    "name": "outlook-ai",
    "version": "1.0.0",
    "description": "Outlook AI - Secure IMAP Client",
    "main": "main.js",
    "scripts": {
        "start": "node server.js",
        "electron": "electron .",
        "build": "electron-builder"
    },
    "dependencies": {
        "body-parser": "^1.20.2",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "express-session": "^1.18.2",
        "mailparser": "^3.9.1",
        "multer": "^1.4.5-lts.1",
        "node-imap": "^0.9.6",
        "nodemailer": "^7.0.12"
    },
    "devDependencies": {
        "electron": "^29.0.0",
        "electron-builder": "^24.13.3"
    },
    "build": {
        "appId": "com.labo.outlookai",
        "productName": "Outlook AI",
        "asar": false,
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*"
        ],
        "win": {
            "target": "nsis"
        }
    }
}